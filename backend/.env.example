# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- MySQL / Railway database credentials ---
MYSQLHOST=your-db-host
MYSQLUSER=your-db-user
MYSQLPASSWORD=your-db-password
MYSQLDATABASE=smart_campus
MYSQLPORT=3306

# --- Server ---
PORT=5000

# --- Frontend URL (used for CORS — set to your Vercel domain) ---
FRONTEND_URL=https://your-app.vercel.app

# --- Razorpay (use test keys for development) ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
